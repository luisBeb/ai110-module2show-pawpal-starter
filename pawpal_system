from dataclasses import dataclass, field
from datetime import datetime
from typing import List

@dataclass
class Owner:
    name: str
    email: str
    pets: List = field(default_factory=list)

    def add_pet(self, pet):
        self.pets.append(pet)

    def get_pets(self):
        return self.pets


@dataclass
class Pet:
    name: str
    species: str
    age: int
    owner: Owner = None

    def get_info(self):
        return f"{self.name} ({self.species}, {self.age} yrs)"


@dataclass
class Task:
    title: str
    duration_minutes: int
    priority: str  # "low", "medium", "high"
    due_date: datetime = field(default_factory=datetime.today)
    pet: object = None
    is_done: bool = False
    recurring: bool = False

    def mark_done(self):
        self.is_done = True

    def is_due_today(self):
        return self.due_date.date() == datetime.today().date()


@dataclass
class Scheduler:
    tasks: List = field(default_factory=list)

    def add_task(self, task):
        self.tasks.append(task)

    def get_today_tasks(self):
        return [t for t in self.tasks if t.is_due_today()]

    def sort_tasks(self):
        priority_order = {"high": 0, "medium": 1, "low": 2}
        self.tasks.sort(key=lambda t: priority_order.get(t.priority, 3))

