classDiagram
    class Owner {
        +String name
        +String email
        +List pets
        +add_pet(pet)
        +get_pets()
    }

    class Pet {
        +String name
        +String species
        +int age
        +Owner owner
        +get_info()
    }

    class Task {
        +String title
        +int duration_minutes
        +String priority
        +datetime due_date
        +bool is_done
        +bool recurring
        +mark_done()
        +is_due_today()
    }

    class Scheduler {
        +List tasks
        +add_task(task)
        +get_today_tasks()
        +sort_tasks()
        +detect_conflicts()
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "many" Task : manages